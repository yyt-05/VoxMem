# VoxMem local development settings
VOXMEM_SERVER_ADDR=:8080
VOXMEM_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
VOXMEM_ENV=development
VOXMEM_ASR_MODE=aliyun
VOXMEM_ASR_MOCK_TEXT=mock final text
VOXMEM_AUDIO_DEBUG_ENABLED=false
VOXMEM_AUDIO_DEBUG_DIR=../tmp/audio-debug
VOXMEM_DB_PATH=../data/voxmem.db

DASHSCOPE_API_KEY=
VOXMEM_LLM_API_KEY=
VOXMEM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VOXMEM_LLM_MODEL=qwen-plus
VOXMEM_LLM_TIMEOUT_SECONDS=8

# Required by POST /api/transcribe/file when voice-filter mode uploads a full WAV
# to Qiniu Kodo before submitting a downloadable URL to DashScope file transcription.
# VOXMEM_KODO_DOMAIN must be reachable by DashScope, with or without https://.
VOXMEM_KODO_ACCESS_KEY=
VOXMEM_KODO_SECRET_KEY=
VOXMEM_KODO_BUCKET=
VOXMEM_KODO_REGION=z0
VOXMEM_KODO_DOMAIN=
VOXMEM_KODO_USE_HTTPS=true
VOXMEM_KODO_PRIVATE_BUCKET=false
VOXMEM_KODO_URL_TTL_SECONDS=3600
VOXMEM_KODO_UPLOAD_PREFIX=audio/
