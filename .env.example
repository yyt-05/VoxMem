# VoxMem local development settings
VOXMEM_SERVER_ADDR=:8080
VOXMEM_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
VOXMEM_ENV=development
VOXMEM_ASR_MODE=aliyun
VOXMEM_ASR_MOCK_TEXT=mock final text
VOXMEM_AUDIO_DEBUG_ENABLED=false
VOXMEM_AUDIO_DEBUG_DIR=../tmp/audio-debug
VOXMEM_DB_PATH=../data/voxmem.db

DASHSCOPE_API_KEY=
VOXMEM_LLM_API_KEY=
VOXMEM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VOXMEM_LLM_MODEL=qwen-plus
VOXMEM_LLM_TIMEOUT_SECONDS=8
